# ============================================
# Manny's ToolBox - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# REQUIRED - Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/mannys_toolbox?schema=public"

# REQUIRED - NextAuth (Authentication)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# REQUIRED - Email Service (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="noreply@mannystoolbox.com"

# OPTIONAL - OpenAI (AI Features)
OPENAI_API_KEY="sk-xxxxxxxxxxxxx"
OPENAI_MODEL="gpt-4o-mini"

# OPTIONAL - Daily Notepad Tool
DAILY_NOTEPAD_DEADLINE_HOUR=9
UPLOAD_DIR="uploads/daily-notepad"

# OPTIONAL - Cron Jobs
CRON_SECRET="your-cron-secret-key-here"

# OPTIONAL - Node Environment
NODE_ENV="development"

# AI providers for the estimate engine (any subset; tasks fall back to whatever key exists)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=...
# Per-task selection (optional): provider = openai | anthropic | google
# AI_EXTRACT_PROVIDER=anthropic
# AI_EXTRACT_MODEL=claude-sonnet-5
# AI_SUGGEST_PROVIDER=openai
# AI_SUGGEST_MODEL=gpt-4o-mini
